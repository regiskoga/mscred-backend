generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------
// 1. CATÁLOGOS ADMINISTRADOS
// -----------------------------------------------------------------------

model Product {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  active      Boolean      @default(true)
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt
  attendances Attendance[]

  @@map("products")
}

model AttendanceStatus {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  active      Boolean      @default(true)
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt
  attendances Attendance[]

  @@map("attendance_statuses")
}

model OperationType {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  active      Boolean      @default(true)
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt
  attendances Attendance[]

  @@map("operation_types")
}

model SalesChannel {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  active      Boolean      @default(true)
  created_at  DateTime     @default(now())
  updated_at  DateTime     @updatedAt
  attendances Attendance[]

  @@map("sales_channels")
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique // OPERADOR, GESTOR, ADMIN
  created_at  DateTime @default(now())
  users       User[]

  @@map("roles")
}

model Holiday {
  id          Int      @id @default(autoincrement())
  name        String
  date        DateTime @db.Date
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  
  @@unique([date])
  @@map("holidays")
}

// -----------------------------------------------------------------------
// 2. ENTIDADES ORGANIZACIONAIS
// -----------------------------------------------------------------------

model Store {
  id          Int          @id @default(autoincrement())
  name        String
  address     String?
  bmg_code    String?      @unique
  created_at  DateTime     @default(now())
  users       User[]
  attendances Attendance[]

  @@map("stores")
}

model User {
  id            String       @id @default(uuid())
  name          String
  email         String       @unique
  password_hash String
  role_id       Int
  role          Role         @relation(fields: [role_id], references: [id])
  store_id      Int?
  store         Store?       @relation(fields: [store_id], references: [id])
  
  avatar_url    String?      @db.Text
  phone         String?
  address       String?

  deleted_at    DateTime?    // Soft delete (Zero-Trust Auditing requirement)
  created_at    DateTime     @default(now())
  updated_at    DateTime     @updatedAt
  
  attendances   Attendance[]

  @@map("users")
}

// -----------------------------------------------------------------------
// 3. ENTIDADE TRANSACIONAL PRINCIPAL 
// -----------------------------------------------------------------------

model Attendance {
  id                   String           @id @default(uuid())
  customer_name        String
  customer_cpf         String           // In future iterations: consider field-level-encryption if PII strictness required by DB layer
  attendance_date      DateTime
  
  product_id           Int
  product              Product          @relation(fields: [product_id], references: [id])
  
  operation_type_id    Int
  operation_type       OperationType    @relation(fields: [operation_type_id], references: [id])
  
  attendance_status_id Int
  attendance_status    AttendanceStatus @relation(fields: [attendance_status_id], references: [id])
  
  sales_channel_id     Int
  sales_channel        SalesChannel     @relation(fields: [sales_channel_id], references: [id])
  
  paid_approved        Boolean          @default(false)
  city                 String
  origin_bank          String?
  
  user_id              String
  user                 User             @relation(fields: [user_id], references: [id])
  
  store_id             Int
  store                Store            @relation(fields: [store_id], references: [id])
  
  created_at           DateTime         @default(now())
  updated_at           DateTime         @updatedAt

  @@map("attendances")
}

// -----------------------------------------------------------------------
// 4. TRILHA DE AUDITORIA (SEC-OPS)
// -----------------------------------------------------------------------

model AuditLog {
  id          String   @id @default(uuid())
  user_id     String?  // Nullable em caso de falhas pre-auth
  action      String   // INSERT, UPDATE, DELETE
  table_name  String
  record_id   String
  old_payload Json?
  new_payload Json?
  ip_address  String?
  timestamp   DateTime @default(now())

  @@index([table_name, record_id])
  @@map("audit_logs")
}
